# ===========================================
# Ollama Signal Bot — Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -------------------------------------------
# Signal Configuration (REQUIRED)
# -------------------------------------------
# The bot's Signal phone number (with country code)
# This must be the number registered on the cloned/secondary Signal app
SIGNAL_PHONE_NUMBER=+1234567890

# -------------------------------------------
# Ollama Configuration
# -------------------------------------------
# URL of your Ollama server
# Use your LAN IP on Linux (host.docker.internal works on Docker Desktop)
OLLAMA_URL=http://192.168.1.100:11434

# Model to use (leave empty for auto-detection of first available model)
OLLAMA_MODEL=gemma4:latest

# -------------------------------------------
# Optional Settings
# -------------------------------------------
# Custom system prompt for the AI
SYSTEM_PROMPT=You are a helpful assistant that answers questions concisely.

# Allowed senders — who can use the bot
#   *                               = allow everyone (default)
#   +15551234567                    = single user
#   +15551234567,+15559876543      = multiple users
ALLOWED_SENDERS=*